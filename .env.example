# Discord application bot token (https://discord.com/developers/applications)
DISCORD_TOKEN=your_bot_token_here

# Channel ID where the auto-updating status embed is posted
STATUS_CHANNEL_ID=1234567890123456789

# Optional: Discord role ID allowed to use /boot and /stop (administrator permission also works)
BOOT_ROLE_ID=

# How often to refresh the status embed (seconds)
REFRESH_INTERVAL_SECONDS=180

# How often to delete all channel messages except the status embed (seconds).
# Set to 0 to disable. Requires Manage Messages permission for the bot.
CHANNEL_PURGE_INTERVAL_SECONDS=3600

# Minecraft server address for mcstatus ping (host network)
MC_HOST=127.0.0.1
MC_PORT=25565

# Public hostname shown in the status embed for players to connect
MC_HOSTNAME=minecraft.example.com

# Docker Compose settings (project root contains compose.yaml)
COMPOSE_DIR=/path/to/your/minecraft-server
COMPOSE_SERVICE=mc

# Boot polling: max seconds to wait for server ping after /boot
BOOT_TIMEOUT_SECONDS=900
